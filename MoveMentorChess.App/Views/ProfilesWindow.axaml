<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:MoveMentorChess.App.Localization"
        xmlns:vm="using:MoveMentorChess.App.ViewModels"
        xmlns:controls="using:Avalonia.Controls"
        x:Class="MoveMentorChess.App.Views.ProfilesWindow"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        WindowState="FullScreen"
        WindowDecorations="None"
        Title="{loc:Localize ProfilesTitle}"
        Background="{DynamicResource ChromeBrush}">
  <Grid RowDefinitions="Auto,*" Margin="18">
    <Border Padding="16" CornerRadius="18" Background="{DynamicResource PanelBrush}">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock VerticalAlignment="Center" FontSize="24" FontWeight="Bold" Text="{loc:Localize ProfilesTitle}" />
        <TextBox x:Name="FilterTextBox"
                 Width="320"
                 VerticalAlignment="Center"
                 PlaceholderText="{loc:Localize ProfilesSearchPlaceholder}"
                 TextChanged="FilterTextBox_OnTextChanged" />
        <Button x:Name="ToggleProfilesButton"
                Content="{loc:Localize ProfilesHidePlayers}"
                Click="ToggleProfilesButton_Click" />
        <Button x:Name="CoachModeButton"
                Content="{loc:Localize ProfilesCoach}"
                Click="CoachModeButton_Click" />
        <Button x:Name="EvidenceModeButton"
                Content="{loc:Localize ProfilesEvidence}"
                Click="EvidenceModeButton_Click" />
        <Button Content="{loc:Localize ProfilesBackToBoard}" Click="CloseButton_Click" />
      </StackPanel>
    </Border>

    <Grid x:Name="ProfilesLayout" Grid.Row="1" Margin="0,14,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border x:Name="ProfilesPanel" Padding="16" CornerRadius="18" Background="{DynamicResource PanelBrush}">
        <StackPanel Spacing="10">
          <TextBlock FontSize="18" FontWeight="SemiBold" Text="{loc:Localize ProfilesAnalyzedPlayers}" />
          <ListBox x:Name="ProfilesListBox"
                   Background="Transparent"
                   SelectionChanged="ProfilesListBox_OnSelectionChanged">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="Transparent" />
              </Style>
              <Style Selector="ListBoxItem:pointerover">
                <Setter Property="Background" Value="#284556" />
              </Style>
              <Style Selector="ListBoxItem:selected">
                <Setter Property="Background" Value="#355D73" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:PlayerProfileSummaryItemViewModel">
                <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" Background="#203542">
                  <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="{Binding Header}" />
                    <TextBlock Foreground="#D7E2EA" Text="{Binding Meta}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border x:Name="DetailsHost" Grid.Column="1" Margin="14,0,0,0" Padding="16" CornerRadius="18" Background="{DynamicResource PanelBrush}">
        <ScrollViewer x:Name="DetailsScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ScrollChanged="DetailsScrollViewer_OnScrollChanged">
          <StackPanel x:Name="DetailsPanel" Spacing="14" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
