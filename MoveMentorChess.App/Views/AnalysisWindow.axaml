<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MoveMentorChess.App.Views.AnalysisWindow"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Title="Imported Game Analysis"
        Background="{DynamicResource ChromeBrush}">
  <Grid Margin="18" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="220,180,*,170,150">
      <ComboBox x:Name="SideComboBox" />
      <ComboBox x:Name="QualityFilterComboBox" Grid.Column="1" Margin="12,0,0,0" />
      <TextBlock x:Name="SummaryTextBlock"
                 Grid.Column="2"
                 Margin="16,0,0,0"
                 VerticalAlignment="Center"
                 Foreground="White"
                 TextWrapping="Wrap" />
      <Button x:Name="AnalyzeButton"
              Grid.Column="3"
              Margin="16,0,0,0"
              Click="AnalyzeButton_Click"
              Content="Run Analysis" />
      <Button x:Name="ShowOnBoardButton"
              Grid.Column="4"
              Margin="12,0,0,0"
              Click="ShowOnBoardButton_Click"
              Content="Show On Board" />
    </Grid>

    <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="*,170">
      <StackPanel>
        <TextBlock x:Name="StatusTextBlock"
                   Foreground="#D7E2EA"
                   Text="Choose a side and run the analysis."
                   TextWrapping="Wrap" />
        <TextBlock x:Name="AdviceStatusTextBlock"
                   Margin="0,6,0,0"
                   Foreground="#9EB5C5"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Button x:Name="TestAdviceButton"
              Grid.Column="1"
              HorizontalAlignment="Right"
              Click="TestAdviceButton_Click"
              Content="Test Advice Model" />
    </Grid>

    <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="360,*">
      <Border Background="White" BorderBrush="#C9C9C9" BorderThickness="1" CornerRadius="8">
        <ListBox x:Name="MistakesListBox"
                 SelectionChanged="MistakesListBox_OnSelectionChanged"
                 DoubleTapped="MistakesListBox_OnDoubleTapped"
                 Background="White"
                 Foreground="Black"
                 BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Foreground" Value="Black" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="#DCE8F2" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="#AFC6D9" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:CompileBindings="False">
              <Grid Margin="8,6" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontWeight="SemiBold"
                           Foreground="#162331"
                           Text="{Binding MoveRange}"
                           TextTrimming="CharacterEllipsis" />
                <Border Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="94"
                        Padding="7,3"
                        CornerRadius="4"
                        Background="{Binding LabelBrush}">
                  <TextBlock HorizontalAlignment="Center"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Foreground="{Binding LabelForeground}"
                             Text="{Binding LabelText}"
                             TextTrimming="CharacterEllipsis" />
                </Border>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#435464"
                           Text="{Binding MetaText}"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Border Grid.Column="1" Margin="14,0,0,0" Background="#101820" BorderBrush="#395061" BorderThickness="1" CornerRadius="8" Padding="12">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <TextBlock x:Name="DetailsTextBlock"
                     Foreground="White"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
