<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MoveMentorChess.App.Views.SettingsWindow"
        Width="520"
        Height="620"
        MinWidth="460"
        MinHeight="560"
        WindowState="FullScreen"
        WindowDecorations="None"
        Title="Settings"
        Background="{DynamicResource ChromeBrush}">
  <Grid RowDefinitions="*,Auto" Margin="18">
    <Border Padding="16"
            CornerRadius="18"
            Background="{DynamicResource PanelBrush}"
            HorizontalAlignment="Center"
            MaxWidth="1180">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Margin="0,0,18,0">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock x:Name="TitleTextBlock" FontSize="24" FontWeight="Bold" Text="Settings" />
            <Button x:Name="CloseButton" Grid.Column="1" Click="CancelButton_Click" Content="Close" />
          </Grid>
          <StackPanel Spacing="10">
            <TextBlock x:Name="IntroTextBlock"
                       Foreground="#D7E2EA"
                       TextWrapping="Wrap"
                       Text="Choose how MoveMentor uses the local model and Stockfish on this machine." />
          </StackPanel>

          <Border Padding="14"
                  CornerRadius="10"
                  Background="{DynamicResource ChromeBrush}"
                  BorderBrush="{DynamicResource PanelAccentBrush}"
                  BorderThickness="1">
            <StackPanel Spacing="8">
              <TextBlock x:Name="SetupChecklistTitleTextBlock"
                         Foreground="White"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Text="Setup checklist" />
              <TextBlock x:Name="SetupChecklistBodyTextBlock"
                         Foreground="#D7E2EA"
                         TextWrapping="Wrap"
                         Text="1. Pick or auto-detect Stockfish. 2. Import a PGN. 3. Run analysis. 4. Follow the training recommendation." />
            </StackPanel>
          </Border>

          <StackPanel Spacing="10">
            <TextBlock x:Name="LanguageLabelTextBlock" FontSize="18" FontWeight="SemiBold" Text="Language" />
            <ComboBox x:Name="LanguageComboBox" />
          </StackPanel>

          <StackPanel Spacing="10">
            <TextBlock x:Name="ModelTitleTextBlock" FontSize="18" FontWeight="SemiBold" Text="Model" />
            <CheckBox x:Name="FullGpuPowerCheckBox"
                      Content="Use full GPU power for the local model" />
            <TextBlock x:Name="LlamaPathLabelTextBlock" Foreground="#D7E2EA" Text="llama-server.exe path (optional)" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox x:Name="LlamaServerPathTextBox"
                       PlaceholderText="Auto-detect llama-server.exe" />
              <Button x:Name="BrowseLlamaButton"
                      Grid.Column="1"
                      MinWidth="110"
                      Content="Browse"
                      Click="BrowseLlamaServerButton_Click" />
            </Grid>
            <TextBlock x:Name="ExplanationLevelLabelTextBlock" Foreground="#D7E2EA" Text="Explanation level" />
            <ComboBox x:Name="ExplanationLevelComboBox" />
            <TextBlock x:Name="NarrationStyleLabelTextBlock" Foreground="#D7E2EA" Text="Narration style" />
            <ComboBox x:Name="NarrationStyleComboBox" />
            <TextBlock x:Name="ModeDescriptionTextBlock"
                       Foreground="#D7E2EA"
                       TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Spacing="10">
            <TextBlock x:Name="StockfishTitleTextBlock" FontSize="18" FontWeight="SemiBold" Text="Stockfish" />
            <TextBlock x:Name="StockfishPathLabelTextBlock" Foreground="#D7E2EA" Text="stockfish.exe path" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox x:Name="StockfishPathTextBox"
                       PlaceholderText="Auto-detect stockfish.exe" />
              <Button x:Name="BrowseStockfishButton"
                      Grid.Column="1"
                      MinWidth="110"
                      Content="Browse"
                      Click="BrowseStockfishButton_Click" />
            </Grid>
            <TextBlock x:Name="EngineThreadsLabelTextBlock" Foreground="#D7E2EA" Text="Engine threads" />
            <NumericUpDown x:Name="StockfishThreadsNumeric"
                           Minimum="1"
                           Maximum="64"
                           Increment="1" />
            <TextBlock x:Name="HashMemoryLabelTextBlock" Foreground="#D7E2EA" Text="Hash memory (MB)" />
            <NumericUpDown x:Name="StockfishHashNumeric"
                           Minimum="16"
                           Maximum="4096"
                           Increment="16" />
            <TextBlock x:Name="BulkDepthLabelTextBlock" Foreground="#D7E2EA" Text="Bulk analysis depth" />
            <NumericUpDown x:Name="BulkDepthNumeric"
                           Minimum="1"
                           Maximum="30"
                           Increment="1" />
            <TextBlock x:Name="BulkMultiPvLabelTextBlock" Foreground="#D7E2EA" Text="Bulk analysis MultiPV" />
            <NumericUpDown x:Name="BulkMultiPvNumeric"
                           Minimum="1"
                           Maximum="5"
                           Increment="1" />
            <TextBlock x:Name="BulkMoveTimeLabelTextBlock" Foreground="#D7E2EA" Text="Bulk analysis move time (ms)" />
            <NumericUpDown x:Name="BulkMoveTimeNumeric"
                           Minimum="25"
                           Maximum="5000"
                           Increment="25" />
            <TextBlock x:Name="StockfishDescriptionTextBlock"
                       Foreground="#D7E2EA"
                       TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="1"
            Margin="0,14,0,0"
            Padding="12"
            CornerRadius="10"
            Background="{DynamicResource PanelBrush}"
            HorizontalAlignment="Center"
            MaxWidth="1180">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="FooterTextBlock"
                   Foreground="#9EB5C5"
                   VerticalAlignment="Center"
                   Text="Save when Stockfish is detected or after choosing a custom path."
                   TextWrapping="Wrap" />
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
          <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" />
          <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
